---
import { SITE, NAV } from '../data/site';
---

<footer class="bg-brun-950 text-beige-100 mt-16">
  <div class="mx-auto max-w-6xl px-4 py-12 grid gap-10 md:grid-cols-3">
    <div>
      <p class="font-display font-bold text-2xl text-white">Croc <span class="text-rouge-400">Cake</span></p>
      <p class="mt-2 text-beige-300 italic">{SITE.slogan}</p>
      <p class="mt-4 text-sm text-beige-300">
        Gâteaux et gâteries pour chiens confectionnés au Québec, offerts dans une centaine
        d’animaleries partenaires.
      </p>
    </div>

    <nav aria-label="Liens du pied de page">
      <p class="font-display font-bold text-lg text-white mb-3">Explorer</p>
      <ul class="space-y-2 text-sm">
        {NAV.map(({ href, label }) => (
          <li><a href={href} class="hover:text-white underline-offset-4 hover:underline">{label}</a></li>
        ))}
        <li><a href="/animaleries" class="hover:text-white underline-offset-4 hover:underline">Espace animaleries</a></li>
      </ul>
    </nav>

    <div>
      <p class="font-display font-bold text-lg text-white mb-3">Nous joindre</p>
      <ul class="space-y-2 text-sm">
        <li>
          <a href={`tel:${SITE.phoneHref}`} class="hover:text-white">📞 {SITE.phone}</a>
        </li>
        <li>
          <a href={`mailto:${SITE.email}`} class="hover:text-white">✉️ {SITE.email}</a>
        </li>
        <li>📍 {SITE.address.locality}, Québec, Canada</li>
      </ul>
      <div class="flex gap-3 mt-4">
        <a href={SITE.social.facebook} rel="noopener" target="_blank" aria-label="Croc Cake sur Facebook"
          class="p-2 rounded-full bg-brun-800 hover:bg-rouge-600 transition-colors">
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href={SITE.social.instagram} rel="noopener" target="_blank" aria-label="Croc Cake sur Instagram"
          class="p-2 rounded-full bg-brun-800 hover:bg-rouge-600 transition-colors">
          <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="border-t border-brun-800">
    <div class="mx-auto max-w-6xl px-4 py-4 text-xs text-beige-400 flex flex-wrap items-center justify-between gap-2">
      <p>
        © {new Date().getFullYear()} {SITE.name} — Tous droits réservés. ·
        <a href="/confidentialite" class="text-beige-200 underline underline-offset-2 hover:text-white">Politique de confidentialité</a>
      </p>
      <p>
        Vous aimeriez avoir nos gâteaux dans votre succursale?
        <a href="/animaleries" class="text-beige-200 underline underline-offset-2 hover:text-white">Cliquez ici!</a>
      </p>
    </div>
  </div>
</footer>
