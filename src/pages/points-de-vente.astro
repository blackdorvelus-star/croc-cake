---
import Base from '../layouts/Base.astro';
import StoreLocator from '../components/StoreLocator.astro';
import { SITE } from '../data/site';
import geocoded from '../data/stores.json';
import pending from '../data/pending-stores.json';

type AnyStore = {
  chain: string;
  branch: string;
  city: string;
  region: string;
  website?: string | null;
  address?: string;
  postalCode?: string;
  phone?: string | null;
};

const REGION_ORDER = [
  'Montréal', 'Laval', 'Lanaudière', 'Laurentides', 'Montérégie', 'Capitale-Nationale',
  'Chaudière-Appalaches', 'Mauricie', 'Estrie', 'Centre-du-Québec', 'Outaouais', 'Abitibi-Témiscamingue',
];

// Les boutiques géocodées utilisent parfois « Lanaudière » sans tiret régional identique — normalise
const all: AnyStore[] = [...(geocoded as AnyStore[]), ...(pending as AnyStore[])];
const byRegion = new Map<string, AnyStore[]>();
for (const s of all) {
  const r = REGION_ORDER.includes(s.region) ? s.region : s.region;
  if (!byRegion.has(r)) byRegion.set(r, []);
  byRegion.get(r)!.push(s);
}
const regions = [...byRegion.keys()].sort(
  (a, b) => (REGION_ORDER.indexOf(a) + 100 * +(REGION_ORDER.indexOf(a) < 0)) - (REGION_ORDER.indexOf(b) + 100 * +(REGION_ORDER.indexOf(b) < 0))
);
const total = all.length;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Animaleries partenaires vendant les produits Croc Cake au Québec',
    numberOfItems: total,
    itemListElement: all.slice(0, 100).map((s, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      item: {
        '@type': 'PetStore',
        name: `${s.chain}${s.branch ? ' — ' + s.branch : ''}`,
        address: {
          '@type': 'PostalAddress',
          ...(s.address ? { streetAddress: s.address } : {}),
          addressLocality: s.city,
          addressRegion: 'QC',
          ...(s.postalCode ? { postalCode: s.postalCode } : {}),
          addressCountry: 'CA',
        },
        ...(s.website ? { url: s.website } : {}),
        ...(s.phone ? { telephone: s.phone } : {}),
      },
    })),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Points de vente', item: `${SITE.url}/points-de-vente` },
    ],
  },
];
---

<Base
  title={`Points de vente — ${total} animaleries partenaires au Québec | Croc Cake`}
  description={`Où acheter les gâteaux pour chiens Croc Cake ? ${total} animaleries partenaires dans 11 régions du Québec : Chico, Animo etc., Le Tourno, Animal Expert et plus. Trouvez la plus proche par code postal.`}
  path="/points-de-vente"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-6xl px-4 py-10 md:py-14">
    <header class="max-w-3xl">
      <h1 class="font-display font-extrabold text-4xl text-brun-950">Points de vente</h1>
      <p class="mt-3 text-lg text-charbon/80">
        Nos gâteaux sont offerts dans <strong>{total} animaleries partenaires</strong> réparties
        dans 11 régions du Québec. Utilisez le localisateur ou parcourez la liste par région.
      </p>
    </header>

    <div class="mt-8">
      <StoreLocator compact />
    </div>

    <nav aria-label="Régions" class="mt-10 flex flex-wrap gap-2">
      {regions.map((r) => (
        <a href={`#region-${r.toLowerCase().replace(/[^a-z0-9]+/gi, '-')}`}
          class="rounded-full bg-beige-100 border border-beige-300 px-4 py-1.5 text-sm font-semibold text-brun-800 hover:border-rouge-500 hover:text-rouge-700 transition-colors">
          {r} ({byRegion.get(r)!.length})
        </a>
      ))}
    </nav>

    {regions.map((r) => (
      <section id={`region-${r.toLowerCase().replace(/[^a-z0-9]+/gi, '-')}`} class="mt-12 scroll-mt-24">
        <h2 class="font-display font-bold text-2xl text-brun-900 border-b-2 border-rouge-200 pb-2">
          📍 {r}
        </h2>
        <ul class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {byRegion.get(r)!.map((s) => (
            <li class="rounded-2xl border border-beige-200 bg-white p-4 shadow-sm">
              <p class="font-display font-bold text-brun-900">{s.chain}</p>
              {s.branch && <p class="text-sm font-semibold text-rouge-700">{s.branch}</p>}
              {s.address ? (
                <p class="mt-1 text-sm text-charbon/80">
                  {s.address}<br />
                  {s.city}, QC {s.postalCode}
                </p>
              ) : (
                <p class="mt-1 text-sm text-charbon/60">{s.city}</p>
              )}
              <div class="mt-2 flex flex-wrap gap-x-4 gap-y-1 text-sm font-semibold">
                {s.phone && (
                  <a href={`tel:${s.phone.replace(/[^0-9+]/g, '')}`} class="text-brun-700 hover:underline">
                    {s.phone}
                  </a>
                )}
                {s.website && (
                  <a href={s.website} rel="noopener" target="_blank" class="text-rouge-700 hover:underline">
                    Site web ↗
                  </a>
                )}
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <div class="mt-16 rounded-3xl bg-beige-100 border border-beige-200 p-8 text-center">
      <h2 class="font-display font-bold text-2xl text-brun-950">Votre animalerie n’est pas dans la liste ?</h2>
      <p class="mt-2 text-charbon/80">
        Suggérez-lui de nous contacter — ou mieux, dites-le-nous et on s’en occupe !
      </p>
      <div class="mt-4 flex flex-wrap justify-center gap-3">
        <a href="/contact" class="rounded-full bg-rouge-600 px-6 py-3 font-display font-bold text-white hover:bg-rouge-700 transition-colors">
          Nous joindre
        </a>
        <a href="/animaleries" class="rounded-full border-2 border-brun-800 px-6 py-3 font-display font-bold text-brun-900 hover:bg-brun-900 hover:text-beige-50 transition-colors">
          Espace animaleries
        </a>
      </div>
    </div>
  </div>
</Base>
