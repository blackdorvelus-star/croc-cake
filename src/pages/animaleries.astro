---
import Base from '../layouts/Base.astro';
import { SITE, PARTNER_PORTAL_URL } from '../data/site';

// Sujet et corps pré-remplis pour le courriel de demande de partenariat,
// livré directement dans la boîte de réception de Croc Cake.
const mailtoPartenaire = `mailto:${SITE.email}?subject=${encodeURIComponent(
  'Demande de partenariat — animalerie'
)}&body=${encodeURIComponent(
  'Bonjour,\n\nNous aimerions offrir les produits Croc Cake dans notre succursale.\n\nNom de la compagnie : \nPersonne à contacter : \nTéléphone : \nEmplacement / nombre de succursales : \n\nMerci !'
)}`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Espace animaleries — devenir détaillant Croc Cake',
    url: `${SITE.url}/animaleries`,
    description:
      'Les animaleries du Québec peuvent offrir les gâteaux pour chiens Croc Cake en boutique. Contactez-nous pour devenir détaillant partenaire.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Animaleries', item: `${SITE.url}/animaleries` },
    ],
  },
];
---

<Base
  title="Animaleries — Offrez les gâteaux Croc Cake dans votre succursale"
  description="Vous êtes une animalerie au Québec ? Rejoignez la centaine de détaillants qui offrent les gâteaux pour chiens Croc Cake. Produit québécois, emballé individuellement, 24 mois de conservation au congélateur."
  path="/animaleries"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-5xl px-4 py-10 md:py-14">
    <header class="max-w-3xl">
      <p class="inline-block rounded-full bg-brun-900 text-beige-50 px-4 py-1 text-sm font-bold">
        🏪 Espace détaillants
      </p>
      <h1 class="mt-3 font-display font-extrabold text-4xl text-brun-950">
        Vous aimeriez avoir nos gâteaux dans votre succursale ?
      </h1>
      <p class="mt-3 text-lg text-charbon/80">
        Rejoignez la centaine d’animaleries québécoises qui font déjà le bonheur de leurs
        clients à quatre pattes avec les produits Croc Cake.
      </p>
    </header>

    <div class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-2xl bg-beige-100 border border-beige-200 p-5">
        <p class="text-2xl">🇨🇦</p>
        <p class="mt-1 font-display font-bold text-brun-900">Produit québécois</p>
        <p class="text-sm text-charbon/70">Confectionné à Laval avec de hauts standards de qualité.</p>
      </div>
      <div class="rounded-2xl bg-beige-100 border border-beige-200 p-5">
        <p class="text-2xl">❄️</p>
        <p class="mt-1 font-display font-bold text-brun-900">Logistique simple</p>
        <p class="text-sm text-charbon/70">Emballage individuel, 24 mois de conservation au congélateur.</p>
      </div>
      <div class="rounded-2xl bg-beige-100 border border-beige-200 p-5">
        <p class="text-2xl">🐶</p>
        <p class="mt-1 font-display font-bold text-brun-900">Clients conquis</p>
        <p class="text-sm text-charbon/70">Un produit festif qui fait revenir les clients en boutique.</p>
      </div>
    </div>

    <div class="mt-10 rounded-3xl bg-white border border-beige-200 shadow-md p-6 md:p-8 text-center">
      <h2 class="font-display font-bold text-2xl text-brun-950">Devenez détaillant partenaire</h2>
      {PARTNER_PORTAL_URL ? (
        <>
          <p class="mt-2 text-charbon/80 max-w-2xl mx-auto">
            Toutes les demandes de partenariat passent par notre espace dédié aux animaleries.
          </p>
          <a href={PARTNER_PORTAL_URL} rel="noopener"
            class="mt-6 inline-block rounded-full bg-brun-900 px-10 py-3.5 font-display font-bold text-lg text-beige-50 hover:bg-brun-700 active:scale-[0.99] shadow-md transition-all">
            Accéder à l’espace partenaires ↗
          </a>
        </>
      ) : (
        <>
          <p class="mt-2 text-charbon/80 max-w-2xl mx-auto">
            Écrivez-nous directement — votre demande arrive tout droit dans notre boîte
            de réception et nous vous répondrons rapidement avec tous les détails.
          </p>
          <a href={mailtoPartenaire}
            class="mt-6 inline-block rounded-full bg-brun-900 px-10 py-3.5 font-display font-bold text-lg text-beige-50 hover:bg-brun-700 active:scale-[0.99] shadow-md transition-all">
            ✉️ Envoyer ma demande par courriel
          </a>
          <p class="mt-3 text-sm text-charbon/60">
            Le courriel s’ouvre pré-rempli dans votre application — il ne reste qu’à compléter et envoyer.
          </p>
        </>
      )}
      <p class="mt-6 text-charbon/70">
        Vous préférez le téléphone ? Appelez-nous au
        <a href={`tel:${SITE.phoneHref}`} class="font-bold text-rouge-700 hover:underline">{SITE.phone}</a>
        ou écrivez à
        <a href={`mailto:${SITE.email}`} class="font-bold text-rouge-700 hover:underline">{SITE.email}</a>.
      </p>
    </div>
  </div>
</Base>
