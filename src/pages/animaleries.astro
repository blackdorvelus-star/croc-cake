---
import Base from '../layouts/Base.astro';
import { SITE, WEB3FORMS_KEY } from '../data/site';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Espace animaleries — devenir détaillant Croc Cake',
    url: `${SITE.url}/animaleries`,
    description:
      'Les animaleries du Québec peuvent offrir les gâteaux pour chiens Croc Cake en boutique. Formulaire de demande pour devenir détaillant partenaire.',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Animaleries', item: `${SITE.url}/animaleries` },
    ],
  },
];
---

<Base
  title="Animaleries — Offrez les gâteaux Croc Cake dans votre succursale"
  description="Vous êtes une animalerie au Québec ? Rejoignez la centaine de détaillants qui offrent les gâteaux pour chiens Croc Cake. Produit québécois, emballé individuellement, 12 mois de conservation au congélateur. Demande en ligne."
  path="/animaleries"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-5xl px-4 py-10 md:py-14">
    <header class="max-w-3xl">
      <p class="inline-block rounded-full bg-brun-900 text-beige-50 px-4 py-1 text-sm font-bold">
        🏪 Espace détaillants
      </p>
      <h1 class="mt-3 font-display font-extrabold text-4xl text-brun-950">
        Vous aimeriez avoir nos gâteaux dans votre succursale ?
      </h1>
      <p class="mt-3 text-lg text-charbon/80">
        Rejoignez la centaine d’animaleries québécoises qui font déjà le bonheur de leurs
        clients à quatre pattes avec les produits Croc Cake.
      </p>
    </header>

    <div class="mt-8 grid gap-4 sm:grid-cols-3">
      <div class="rounded-2xl bg-beige-100 border border-beige-200 p-5">
        <p class="text-2xl">🇨🇦</p>
        <p class="mt-1 font-display font-bold text-brun-900">Produit québécois</p>
        <p class="text-sm text-charbon/70">Confectionné à Laval avec de hauts standards de qualité.</p>
      </div>
      <div class="rounded-2xl bg-beige-100 border border-beige-200 p-5">
        <p class="text-2xl">❄️</p>
        <p class="mt-1 font-display font-bold text-brun-900">Logistique simple</p>
        <p class="text-sm text-charbon/70">Emballage individuel, 12 mois de conservation au congélateur.</p>
      </div>
      <div class="rounded-2xl bg-beige-100 border border-beige-200 p-5">
        <p class="text-2xl">🐶</p>
        <p class="mt-1 font-display font-bold text-brun-900">Clients conquis</p>
        <p class="text-sm text-charbon/70">Un produit festif qui fait revenir les clients en boutique.</p>
      </div>
    </div>

    <form action="https://api.web3forms.com/submit" method="POST" class="mt-10 rounded-3xl bg-white border border-beige-200 shadow-md p-6 md:p-8">
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="Demande d’animalerie — croccake.com/animaleries" />
      <input type="hidden" name="from_name" value="Site web Croc Cake (espace animaleries)" />
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
      <input type="hidden" name="redirect" value={`${SITE.url}/merci`} />

      <h2 class="font-display font-bold text-2xl text-brun-950">Formulaire de demande</h2>
      <p class="mt-1 text-charbon/70 text-sm">Nous vous répondrons rapidement avec tous les détails.</p>

      <div class="mt-5 grid gap-4 sm:grid-cols-2">
        <div>
          <label for="compagnie" class="block font-semibold text-sm text-brun-900">Nom de votre compagnie *</label>
          <input id="compagnie" name="compagnie" type="text" required autocomplete="organization"
            class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors" />
        </div>
        <div>
          <label for="personne" class="block font-semibold text-sm text-brun-900">Nom de la personne qui contacte *</label>
          <input id="personne" name="personne_contact" type="text" required autocomplete="name"
            class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors" />
        </div>
        <div>
          <label for="telephone" class="block font-semibold text-sm text-brun-900">Téléphone *</label>
          <input id="telephone" name="telephone" type="tel" required autocomplete="tel"
            class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors" />
        </div>
        <div>
          <label for="courriel" class="block font-semibold text-sm text-brun-900">Courriel *</label>
          <input id="courriel" name="email" type="email" required autocomplete="email"
            class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors" />
        </div>
      </div>
      <div class="mt-4">
        <label for="demande" class="block font-semibold text-sm text-brun-900">Votre demande *</label>
        <textarea id="demande" name="demande" rows="6" required
          class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors"
          placeholder="Parlez-nous de votre boutique : emplacement, nombre de succursales, clientèle…"></textarea>
      </div>
      <button type="submit"
        class="mt-6 w-full rounded-full bg-brun-900 px-8 py-3.5 font-display font-bold text-lg text-beige-50 hover:bg-brun-700 active:scale-[0.99] shadow-md transition-all">
        Envoyer ma demande
      </button>
      <p class="mt-3 text-xs text-charbon/60 text-center">
        En soumettant ce formulaire, vous consentez à ce que nous utilisions ces renseignements
        dans le seul but de traiter votre demande de partenariat. Détails dans notre
        <a href="/confidentialite" class="underline hover:text-rouge-700">politique de confidentialité</a>.
      </p>
    </form>

    <p class="mt-6 text-center text-charbon/70">
      Vous préférez le téléphone ? Appelez-nous au
      <a href={`tel:${SITE.phoneHref}`} class="font-bold text-rouge-700 hover:underline">{SITE.phone}</a>
      ou écrivez à
      <a href={`mailto:${SITE.email}`} class="font-bold text-rouge-700 hover:underline">{SITE.email}</a>.
    </p>
  </div>
</Base>
