---
import Base from '../layouts/Base.astro';
import { SITE, WEB3FORMS_KEY } from '../data/site';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact — Croc Cake',
    url: `${SITE.url}/contact`,
    about: { '@id': `${SITE.url}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Accueil', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Contact', item: `${SITE.url}/contact` },
    ],
  },
];
---

<Base
  title="Contact | Croc Cake — 514-265-2824"
  description="Contactez Croc Cake : téléphone 514-265-2824, courriel info@croccake.com. Suivez-nous sur Facebook et Instagram. Basés à Laval, Québec."
  path="/contact"
  jsonLd={jsonLd}
>
  <div class="mx-auto max-w-5xl px-4 py-10 md:py-14">
    <header class="max-w-3xl">
      <h1 class="font-display font-extrabold text-4xl text-brun-950">Contactez-nous</h1>
      <p class="mt-3 text-lg text-charbon/80">
        Une question sur nos produits, une commande spéciale, une idée folle de gâteau ?
        On jappe de joie à l’idée de vous lire.
      </p>
    </header>

    <div class="mt-10 grid gap-8 md:grid-cols-5">
      <!-- Coordonnées -->
      <div class="md:col-span-2 space-y-4">
        <a href={`tel:${SITE.phoneHref}`} class="block rounded-2xl bg-white border border-beige-200 p-5 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-2xl">📞</p>
          <p class="mt-1 font-display font-bold text-brun-900">Téléphone</p>
          <p class="text-rouge-700 font-semibold">{SITE.phone}</p>
        </a>
        <a href={`mailto:${SITE.email}`} class="block rounded-2xl bg-white border border-beige-200 p-5 shadow-sm hover:shadow-md transition-shadow">
          <p class="text-2xl">✉️</p>
          <p class="mt-1 font-display font-bold text-brun-900">Courriel</p>
          <p class="text-rouge-700 font-semibold">{SITE.email}</p>
        </a>
        <div class="rounded-2xl bg-white border border-beige-200 p-5 shadow-sm">
          <p class="text-2xl">📍</p>
          <p class="mt-1 font-display font-bold text-brun-900">Atelier</p>
          <p class="text-charbon/80">Laval, Québec, Canada</p>
        </div>
        <div class="rounded-2xl bg-white border border-beige-200 p-5 shadow-sm">
          <p class="text-2xl">💬</p>
          <p class="mt-1 font-display font-bold text-brun-900">Réseaux sociaux</p>
          <div class="mt-2 flex gap-3">
            <a href={SITE.social.facebook} rel="noopener" target="_blank" aria-label="Croc Cake sur Facebook"
              class="flex items-center gap-2 rounded-full bg-beige-100 px-4 py-2 text-sm font-bold text-brun-800 hover:bg-rouge-600 hover:text-white transition-colors">
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebook
            </a>
            <a href={SITE.social.instagram} rel="noopener" target="_blank" aria-label="Croc Cake sur Instagram"
              class="flex items-center gap-2 rounded-full bg-beige-100 px-4 py-2 text-sm font-bold text-brun-800 hover:bg-rouge-600 hover:text-white transition-colors">
              <svg class="h-4 w-4 fill-current" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
              Instagram
            </a>
          </div>
        </div>
        <div class="rounded-2xl bg-rouge-600 text-white p-5 shadow-md">
          <p class="font-display font-bold text-lg">Vous aimeriez avoir nos gâteaux dans votre succursale ?</p>
          <a href="/animaleries" class="mt-3 inline-block rounded-full bg-white px-5 py-2 font-bold text-rouge-700 hover:bg-beige-100 transition-colors">
            Cliquez ici !
          </a>
        </div>
      </div>

      <!-- Formulaire -->
      <form action="https://api.web3forms.com/submit" method="POST" class="md:col-span-3 rounded-3xl bg-white border border-beige-200 shadow-md p-6 md:p-8">
        <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
        <input type="hidden" name="subject" value="Nouveau message — croccake.com" />
        <input type="hidden" name="from_name" value="Site web Croc Cake" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />
        <input type="hidden" name="redirect" value={`${SITE.url}/merci`} />

        <h2 class="font-display font-bold text-2xl text-brun-950">Écrivez-nous</h2>

        <div class="mt-5 grid gap-4 sm:grid-cols-2">
          <div>
            <label for="nom" class="block font-semibold text-sm text-brun-900">Votre nom *</label>
            <input id="nom" name="nom" type="text" required autocomplete="name"
              class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors" />
          </div>
          <div>
            <label for="courriel" class="block font-semibold text-sm text-brun-900">Votre courriel *</label>
            <input id="courriel" name="email" type="email" required autocomplete="email"
              class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors" />
          </div>
        </div>
        <div class="mt-4">
          <label for="telephone" class="block font-semibold text-sm text-brun-900">Téléphone (facultatif)</label>
          <input id="telephone" name="telephone" type="tel" autocomplete="tel"
            class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors" />
        </div>
        <div class="mt-4">
          <label for="message" class="block font-semibold text-sm text-brun-900">Votre message *</label>
          <textarea id="message" name="message" rows="6" required
            class="mt-1 w-full rounded-xl border-2 border-beige-300 bg-beige-50 px-4 py-2.5 outline-none focus:border-rouge-500 transition-colors"
            placeholder="Parlez-nous de votre animour et de ce qui vous ferait plaisir…"></textarea>
        </div>
        <button type="submit"
          class="mt-6 w-full rounded-full bg-rouge-600 px-8 py-3.5 font-display font-bold text-lg text-white hover:bg-rouge-700 active:scale-[0.99] shadow-md transition-all">
          Envoyer le message
        </button>
        <p class="mt-3 text-xs text-charbon/60 text-center">
          En soumettant ce formulaire, vous consentez à ce que nous utilisions ces renseignements
          dans le seul but de vous répondre — aucune infolettre surprise. Détails dans notre
          <a href="/confidentialite" class="underline hover:text-rouge-700">politique de confidentialité</a>.
        </p>
      </form>
    </div>
  </div>
</Base>
